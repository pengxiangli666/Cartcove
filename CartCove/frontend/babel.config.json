{
    "presets": [
        [
            "@babel/preset-env",
            {
                "targets": {
                    "node": "18"
                }
            }
        ],
        "@babel/preset-react",
        ["@babel/preset-typescript", {
            "rewriteImportExtensions" : true
        }]

    ],
    "plugins": ["@babel/plugin-proposal-class-properties"]
}